QMainWindow {
    background-color: #F5F7F8;
    color: #171A1F;
    font-family: "Microsoft YaHei UI", "Microsoft YaHei", "Segoe UI", sans-serif;
    font-size: 14px;
}

QWidget {
    color: #20242A;
    font-family: "Microsoft YaHei UI", "Microsoft YaHei", "Segoe UI", sans-serif;
    font-size: 14px;
}

#appRoot {
    background-color: #F5F7F8;
}

QToolTip {
    color: #FFFFFF;
    background-color: #262B33;
    border: none;
    padding: 6px 8px;
}
